<div class="min-h-screen flex items-center justify-center px-8 py-12" style="font-family: 'Georgia', serif; background-color: #23003F;">
  <div class="w-full max-w-md bg-white rounded-3xl shadow-xl p-8">
    <h2 class="text-3xl font-black mb-6 text-center" style="color: #23003F;">
      Sign up
    </h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-bold mb-2", style: "color: #23003F;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#7D39EB]" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-bold mb-2", style: "color: #23003F;" %>
        <% if @minimum_password_length %>
          <p class="text-xs mb-2" style="color: #7D39EB;">
            (<%= @minimum_password_length %> characters minimum)
          </p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full px-4 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#7D39EB]" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, class: "block text-sm font-bold mb-2", style: "color: #23003F;" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full px-4 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#7D39EB]" %>
      </div>

      <div class="mt-6">
        <%= f.submit "Sign up",
              class: "w-full px-6 py-3 rounded-full font-black uppercase text-sm shadow-md",
              style: "background-color: #C6FF33; color: #23003F;" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

