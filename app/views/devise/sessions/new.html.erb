<div class="min-h-screen flex items-center justify-center px-8 py-12" style="font-family: 'Georgia', serif; background-color: #23003F;">
  <div class="w-full max-w-md bg-white rounded-3xl shadow-xl p-8">
    <h2 class="text-3xl font-black mb-6 text-center" style="color: #23003F;">
      Log in
    </h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-bold mb-2", style: "color: #23003F;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#7D39EB]" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-bold mb-2", style: "color: #23003F;" %>
        <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full px-4 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#7D39EB]" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-4">
          <%= f.check_box :remember_me, class: "mr-2 rounded border-gray-300 text-[#7D39EB] focus:ring-[#7D39EB]" %>
          <%= f.label :remember_me, class: "text-sm font-medium", style: "color: #23003F;" %>
        </div>
      <% end %>

      <div class="mt-6">
        <%= f.submit "Log in",
              class: "w-full px-6 py-3 rounded-full font-black uppercase text-sm shadow-md",
              style: "background-color: #F2619C; color: white;" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

