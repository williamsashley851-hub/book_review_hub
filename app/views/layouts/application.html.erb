<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Book Review Hub" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Book Review Hub">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
<div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
  <div class="absolute -top-20 -right-20 w-96 h-96 opacity-30"
       style="background-color: <%= ['#FF639B', '#3CBF96'].sample %>; 
              border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
              transform: rotate(<%= rand(0..360) %>deg);">
  </div>
  <div class="absolute -bottom-20 -left-20 w-96 h-96 opacity-30"
       style="background-color: <%= ['#FF639B', '#3CBF96'].sample %>; 
              border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
              transform: rotate(<%= rand(0..360) %>deg);">
  </div>
</div>
<nav class="bg-gray-900 text-white px-6 py-4 flex items-center justify-between">
  <div class="flex gap-3 items-center">
    <%= link_to "Home", root_path, class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90", style: "background-color: #FF639B" %>
    <%= link_to "Books", books_path, class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90", style: "background-color: #2E90CF" %>
  </div>

  <div class="flex items-center gap-2">
    <%= image_tag "logo.jpg", class: "h-16 w-16 rounded-full" %>
    <%= link_to "HappyFlower Review Hub", root_path, class: "text-white text-3xl font-bold hover:text-green-300" %>
  </div>

  <div class="flex gap-3 items-center">
    <% if user_signed_in? %>
      <%= link_to "My Reviews", my_reviews_path, class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90", style: "background-color: #3CBF96" %>
      <%= button_to "Logout", destroy_user_session_path, method: :delete, data: { turbo: false }, class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90", style: "background-color: #FF4040; border: none; cursor: pointer;" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90", style: "background-color: #3CBF96" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90", style: "background-color: #FFDF51; color: black;" %>
    <% end %>
  </div>
</nav>
     <% if notice || alert %>
	     <p class="notice"><%= notice %></p>
       <p class="alert"><%= alert %></p>
    <% end %>

    <%= yield %>
  </body>
</html>
