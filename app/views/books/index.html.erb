<% content_for :title, "Home" %>

<div class="min-h-screen px-8 py-12" style="font-family: 'Georgia', serif;">

  <%# Header %>
  <div class="text-center mb-16 relative">
    <p class="text-sm font-bold tracking-widest uppercase mb-2" style="color: #7D39EB;">— discover your next obsession —</p>
    <h1 class="text-6xl font-black mb-4" style="color: #23003F; letter-spacing: -2px;">
      The <span style="color: #F2619C; -webkit-text-stroke: 1px #23003F;">Shelf</span>
    </h1>
    <div class="flex items-center justify-center gap-3">
      <div class="h-px w-24" style="background: #C6FF33;"></div>
      <span style="color: #7D39EB; font-size: 1.2rem;">✦</span>
      <div class="h-px w-24" style="background: #C6FF33;"></div>
    </div>
  </div>

  <%# Grid %>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 max-w-7xl mx-auto">
    <% colors = [ '#BCACCE'] %>
    <% @books.each_with_index do |book, i| %>
      <% card_color = colors[i % colors.length] %>
      <% text_color = 'black' %>
      
      <div class="group relative rounded-3xl overflow-hidden cursor-pointer"
           style="background-color: <%= card_color %>; min-height: 480px; transition: transform 0.3s ease, box-shadow 0.3s ease;"
           onmouseover="this.style.transform='translateY(-8px) rotate(1deg)'; this.style.boxShadow='8px 12px 0px #23003F';"
           onmouseout="this.style.transform='translateY(0) rotate(0deg)'; this.style.boxShadow='none';">

        <%# Top decorative stripe %>
        <div class="h-2 w-full" style="background-color: #23003F;"></div>

        <div class="p-6 flex flex-col justify-between h-full">
          
          <%# Genre badge %>
          <div class="mb-4">
            <span class="text-xs font-black uppercase tracking-widest px-3 py-1 rounded-full"
                  style="background-color: #FFFFFF; color: #23003F;">
              <%= book.genre %>
            </span>
          </div>

          <%# Book cover image %>
<div class="100 w-full overflow-hidden rounded-xl mb-4">
  <% if book.cover_url.present? %>
    <%= image_tag book.cover_url, class: "w-full h-full object-cover" %>
  <% else %>
    <div class="w-full h-full flex items-center justify-center text-5xl" style="background-color: #23003F;">
      📚
    </div>
  <% end %>
</div>

          <%# Title %>
          <h2 class="text-xl font-black leading-tight mb-1" style="color: <%= text_color %>;">
            <%= book.title %>
          </h2>

          <%# Author %>
          <p class="text-sm font-medium mb-6" style="color: <%= text_color %>; opacity: 0.8;">
            by <%= book.author %>
          </p>

          <%# CTA link with zigzag underline effect %>
          <%= link_to book, class: "inline-block text-sm font-black uppercase tracking-wider",
              style: "color: #{text_color};" do %>
            Read Reviews →
          <% end %>
        </div>

        <%# Bottom decorative stripe %>
        <div class="h-2 w-full absolute bottom-0" style="background-color: #23003F;"></div>
      </div>
    <% end %>
  </div>

  <%# Add Book button %>
  <% if user_signed_in? %>
    <div class="text-center mt-16">
      <%= link_to new_book_path,
          class: "inline-block px-8 py-4 rounded-full font-black text-lg uppercase tracking-wider",
          style: "background-color: #23003F; color: #C6FF33; border: 3px solid #C6FF33; transition: all 0.2s;",
          onmouseover: "this.style.backgroundColor='#C6FF33'; this.style.color='#23003F';",
          onmouseout: "this.style.backgroundColor='#23003F'; this.style.color='#C6FF33';" do %>
        + Add a Book
      <% end %>
    </div>
  <% end %>

</div>
  