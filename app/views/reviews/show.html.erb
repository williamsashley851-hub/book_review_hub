<div class="min-h-screen px-8 py-12" 
     style="font-family: 'Georgia', serif; background-image: url('/assets/wallpaper.jpg'); background-size: cover; background-position: center;">
  <div class="max-w-3xl mx-auto bg-white bg-opacity-90 rounded-2xl p-8 shadow-lg">
    <h1 class="text-3xl font-black mb-6" style="color: #23003F;">
      Review for <%= @book.title %>
    </h1>

    <div class="rounded-2xl p-6 shadow-md" style="background-color: #F8F4FF; border-left: 4px solid #7D39EB;">
      <p style="color: #23003F;"><%= @review.content %></p>
      <span class="px-3 py-1 rounded-full text-sm font-black mt-2 inline-block"
            style="background-color: #7D39EB; color: white;">
        ⭐ <%= @review.rating %>/5
      </span>
    </div>

    <div class="flex gap-3 mt-6">
      <%= link_to "Edit Review", edit_book_review_path(@book, @review),
                  class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90",
                  style: "background-color: #2E90CF" %>

      <%= link_to "Back to My Reviews", my_reviews_path,
                  class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90",
                  style: "background-color: #FFDF51; color: black;" %>

      <%= button_to "Delete Review", book_review_path(@book, @review),
                    method: :delete,
                    data: { confirm: "Are you sure you want to delete this review?" },
                    class: "px-4 py-2 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90",
                    style: "background-color: #FF4040; border: none; cursor: pointer;" %>
    </div>
  </div>
</div>

