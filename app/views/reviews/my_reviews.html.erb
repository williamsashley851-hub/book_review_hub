<div class="min-h-screen px-8 py-12" 
     style="font-family: 'Georgia', serif; background-image: url('/assets/wallpaper.jpg'); background-size: cover; background-position: center;">
  <div class="max-w-4xl mx-auto bg-white bg-opacity-90 rounded-2xl p-8 shadow-lg">
    <h1 class="text-3xl font-black mb-8" style="color: #23003F;">My Reviews</h1>

    <% if @reviews.empty? %>
      <div class="text-center py-16 rounded-3xl" style="background-color: #BCACCE20;">
        <p class="text-2xl font-black" style="color: #23003F;">You haven’t written any reviews yet</p>
        <p class="mt-2" style="color: #7D39EB;">Browse books and share your thoughts!</p>
      </div>
    <% else %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% @reviews.each do |review| %>
          <div class="rounded-2xl p-6 shadow-md" style="background-color: #F8F4FF; border-left: 4px solid #7D39EB;">
            <h2 class="font-black mb-2" style="color: #23003F;"><%= review.book.title %></h2>
            <p style="color: #23003F;"><%= review.content %></p>
            <span class="px-3 py-1 rounded-full text-sm font-black mt-2 inline-block"
                  style="background-color: #7D39EB; color: white;">
              ⭐ <%= review.rating %>/5
            </span>

            <div class="mt-4">
              <%= link_to "View", book_review_path(review.book, review),
            class: "px-3 py-1 rounded-full font-bold text-white transition-transform duration-200 hover:scale-110 hover:opacity-90",
            style: "background-color: #3CBF96" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>


